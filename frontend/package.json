{
  "name": "salon-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite --config web/vite.config.js",
    "dev:admin": "vite --config admin/vite.config.js --port 5174",
    "build:web": "vite build --config web/vite.config.js",
    "build:admin": "vite build --config admin/vite.config.js",
    "build": "npm run build:web && npm run build:admin"
  },
  "dependencies": {
    "jalaali-js": "^1.2.8",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-date-object": "^2.1.9",
    "react-dom": "^18.3.1",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3"
  }
}
